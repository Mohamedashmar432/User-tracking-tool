<Window x:Class="TelemetryAgent.UI.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TelemetryAgent"
        Width="320" Height="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

  <Window.Resources>
    <Style x:Key="Label" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#9ca3af"/>
      <Setter Property="FontSize"   Value="11"/>
    </Style>
    <Style x:Key="Value" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#f9fafb"/>
      <Setter Property="FontSize"   Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </Window.Resources>

  <!-- Outer drop-shadow wrapper -->
  <Border Margin="8" CornerRadius="12"
          Background="#111827"
          BorderBrush="#1f2937" BorderThickness="1">
    <Border.Effect>
      <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
    </Border.Effect>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="48"/>   <!-- header -->
        <RowDefinition Height="*"/>    <!-- content -->
        <RowDefinition Height="40"/>   <!-- footer -->
      </Grid.RowDefinitions>

      <!-- ── Header ──────────────────────────────────────────────────────── -->
      <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#0d1117">
        <Grid Margin="16,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#4ade80" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusLabel" Text="Active" Foreground="#f9fafb"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
          <Button x:Name="CloseBtn" Content="✕" HorizontalAlignment="Right"
                  Background="Transparent" BorderThickness="0"
                  Foreground="#6b7280" FontSize="14" Cursor="Hand"
                  Click="CloseBtn_Click"/>
        </Grid>
      </Border>

      <!-- ── Content ─────────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
        <StackPanel Margin="16,12,16,0">

          <!-- Score ring + label -->
          <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
            <Canvas x:Name="DonutCanvas" Width="140" Height="140"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock x:Name="ScoreText" Text="--" Foreground="#f9fafb"
                         FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
              <TextBlock Text="score" Style="{StaticResource Label}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- KPI row -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock x:Name="ActiveTimeText" Text="--" Style="{StaticResource Value}" HorizontalAlignment="Center"/>
              <TextBlock Text="Active" Style="{StaticResource Label}" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock x:Name="TopAppText" Text="--" Style="{StaticResource Value}" HorizontalAlignment="Center"
                         TextTrimming="CharacterEllipsis" MaxWidth="90"/>
              <TextBlock Text="Top App" Style="{StaticResource Label}" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock x:Name="IdleTimeText" Text="--" Style="{StaticResource Value}" HorizontalAlignment="Center"/>
              <TextBlock Text="Idle" Style="{StaticResource Label}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Divider -->
          <Rectangle Height="1" Fill="#1f2937" Margin="0,0,0,16"/>

          <!-- 24h Activity chart -->
          <TextBlock Text="24-Hour Activity" Style="{StaticResource Label}" Margin="0,0,0,8"/>
          <Canvas x:Name="ActivityCanvas" Height="70" Margin="0,0,0,4"/>

          <!-- Hour labels -->
          <Grid Margin="0,0,0,16">
            <TextBlock Text="12am" Style="{StaticResource Label}" HorizontalAlignment="Left"/>
            <TextBlock Text="12pm" Style="{StaticResource Label}" HorizontalAlignment="Center"/>
            <TextBlock Text="11pm" Style="{StaticResource Label}" HorizontalAlignment="Right"/>
          </Grid>

          <!-- Current app -->
          <Rectangle Height="1" Fill="#1f2937" Margin="0,0,0,12"/>
          <TextBlock Text="Current App" Style="{StaticResource Label}" Margin="0,0,0,4"/>
          <TextBlock x:Name="CurrentAppText" Text="—" Foreground="#e5e7eb"
                     FontSize="13" TextTrimming="CharacterEllipsis"/>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Footer ──────────────────────────────────────────────────────── -->
      <Border Grid.Row="2" CornerRadius="0,0,12,12" Background="#0d1117">
        <Grid Margin="16,0">
          <TextBlock x:Name="LastUpdatedText" Text="Refreshing…" Style="{StaticResource Label}"
                     VerticalAlignment="Center"/>
          <Button x:Name="RefreshBtn" Content="↻ Refresh" HorizontalAlignment="Right"
                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                  Foreground="#6b7280" FontSize="12" Cursor="Hand"
                  Click="RefreshBtn_Click"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
